{% extends 'layout.html.twig' %}

{% block title %}Добавление метки{% endblock %}

{% block content %}
    <h1 class="h3 mb-4">Добавление метки</h1>

    {% if error is defined and error %}
        <div class="alert alert-danger" role="alert">{{ error }}</div>
    {% endif %}

    <section class="placemark-section placemark-section--map mb-4">
        <div
            id="placemark-map"
            class="placemark-map"
            data-center-lat="{{ mapCenterLat }}"
            data-center-lon="{{ mapCenterLon }}"
            data-api-url="{{ path('api_placemarker_create') }}"
            data-api-base="{{ path('api_placemarker_create') }}"
            data-initial-placemarkers="{{ (savedPlacemarkers|default([]))|json_encode|e('html_attr') }}"
        ></div>
    </section>

    <section id="placemark-new-form" class="placemark-section placemark-section--form mb-4">
        <div class="placemark-section__header">
            <h2 class="placemark-section__title h5 mb-0">Новая метка</h2>
            <p class="placemark-section__hint mb-0">Кликните по карте, заполните поля и сохраните</p>
        </div>
        <div class="placemark-section__body">
            <form class="placemark-form" novalidate>
                <div class="placemark-form-layout">
                    <div class="placemark-form-layout__main">
                        <div class="placemark-form-panel">
                            <div class="placemark-form-field">
                                <label class="form-label placemark-form-label">
                                    <span class="placemark-form-label__icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                                    </span>
                                    Название
                                    <span class="placemark-form-label__required" title="Обязательное поле" aria-hidden="true">*</span>
                                    <span class="visually-hidden"> (обязательно)</span>
                                </label>
                                <input type="text" class="form-control placemark-name" placeholder="Название метки" required>
                            </div>

                            <div class="placemark-form-coords">
                                <div class="placemark-form-field">
                                    <label class="form-label placemark-form-label">
                                        <span class="placemark-form-label__icon" aria-hidden="true">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                                        </span>
                                        Широта (lat)
                                        <span class="placemark-form-label__required" title="Обязательное поле" aria-hidden="true">*</span>
                                        <span class="visually-hidden"> (обязательно)</span>
                                    </label>
                                    <input type="text" class="form-control placemark-lat coords" placeholder="59.94000000" required>
                                </div>
                                <div class="placemark-form-field">
                                    <label class="form-label placemark-form-label">
                                        <span class="placemark-form-label__icon" aria-hidden="true">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                                        </span>
                                        Долгота (lon)
                                        <span class="placemark-form-label__required" title="Обязательное поле" aria-hidden="true">*</span>
                                        <span class="visually-hidden"> (обязательно)</span>
                                    </label>
                                    <input type="text" class="form-control placemark-lon coords" placeholder="30.31000000" required>
                                </div>
                            </div>

                            <div class="placemark-form-field">
                                <label class="form-label placemark-form-label">
                                    <span class="placemark-form-label__icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    </span>
                                    Тип метки
                                </label>
                                <select class="form-select placemark-type">
                                    {% for type in placemarkerTypes|default([]) %}
                                        <option value="{{ type.slug }}">{{ type.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="placemark-form-tags">
                                <button type="button" class="placemark-form-tags-btn" data-bs-toggle="modal" data-bs-target="#placemark-tags-modal">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                    Добавить теги
                                </button>
                                <div id="selected-tags-container" class="placemark-form-tags-chips"></div>
                            </div>
                        </div>
                    </div>

                    <div class="placemark-form-layout__aside">
                        <div class="placemark-form-panel placemark-form-panel--description">
                            <label class="form-label placemark-form-label">
                                <span class="placemark-form-label__icon" aria-hidden="true">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                                </span>
                                Описание
                            </label>
                            <textarea class="form-control placemark-description placemark-form-description__input" placeholder="Расскажите подробнее о месте: что здесь интересного, как добраться…"></textarea>
                        </div>
                    </div>
                </div>

                <div class="placemark-form-actions">
                    <button type="button" class="btn btn-primary placemark-save px-4">
                        <span class="btn-label">Сохранить</span>
                    </button>
                </div>
            </form>
        </div>
    </section>

    <section class="placemark-section placemark-section--cards">
        <div class="placemark-section__header">
            <h2 class="placemark-section__title h5 mb-0">Сохранённые метки</h2>
            <p class="placemark-section__hint mb-0">Нажмите на карточку, чтобы изменить название и описание</p>
        </div>
        <div class="placemark-section__body">
            <div id="placemark-saved-list" class="row g-2 placemark-saved-list"></div>
            <p class="placemark-cards-empty mb-0">Пока нет сохранённых меток</p>
        </div>
    </section>

    <template id="placemark-saved-card-template">
        <div class="col-6 col-sm-4 col-md-3 col-lg-1">
            <div class="card placemark-saved-card h-100" role="button" tabindex="0">
                <div class="card-body position-relative text-center p-3">
                    <button type="button" class="btn-close btn-close-sm placemark-saved-remove" aria-label="Удалить"></button>
                    <div class="placemark-saved-pin" aria-hidden="true">📍</div>
                    <div class="placemark-saved-name fw-semibold text-truncate" title=""></div>
                    <div class="placemark-saved-coords mt-1">
                        <div class="placemark-saved-lat text-truncate" title=""></div>
                        <div class="placemark-saved-lon text-truncate" title=""></div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <div class="modal fade placemark-edit-modal" id="placemark-edit-modal" tabindex="-1" aria-labelledby="placemark-edit-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered placemark-edit-modal-dialog">
            <div class="modal-content placemark-edit-modal-content">
                <div class="modal-header placemark-edit-modal-header">
                    <h5 class="modal-title" id="placemark-edit-modal-label">Редактирование метки</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <form id="placemark-edit-form" novalidate>
                        <input type="hidden" id="placemark-edit-id">
                        <div class="mb-3">
                            <label for="placemark-edit-name" class="form-label">Название</label>
                            <input type="text" class="form-control" id="placemark-edit-name" required>
                        </div>
                        <div class="mb-3">
                            <label for="placemark-edit-type" class="form-label">Тип метки</label>
                            <select class="form-select" id="placemark-edit-type">
                                {% for type in placemarkerTypes|default([]) %}
                                    <option value="{{ type.slug }}">{{ type.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="placemark-edit-coords mb-3">
                            <label class="form-label d-block text-center">Координаты</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label for="placemark-edit-lat" class="form-label small text-muted mb-1">Широта (lat)</label>
                                    <input type="text" class="form-control form-control-sm text-center" id="placemark-edit-lat" readonly>
                                </div>
                                <div class="col-6">
                                    <label for="placemark-edit-lon" class="form-label small text-muted mb-1">Долгота (lon)</label>
                                    <input type="text" class="form-control form-control-sm text-center" id="placemark-edit-lon" readonly>
                                </div>
                            </div>
                        </div>
                        <div class="mb-0">
                            <label for="placemark-edit-description" class="form-label">Описание</label>
                            <textarea class="form-control" id="placemark-edit-description" rows="4" placeholder="Добавьте описание метки"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer placemark-edit-modal-footer justify-content-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary px-4" id="placemark-edit-save">
                        <span class="btn-label">Сохранить</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade placemark-tags-modal" id="placemark-tags-modal" tabindex="-1" aria-labelledby="placemark-tags-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="placemark-tags-modal-label">Выберите теги</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="placemark-tags-list d-flex flex-wrap gap-2" id="available-tags-container">
                        {% if userTags|default([]) is empty %}
                            <p class="text-muted w-100 text-center mb-0">У вас пока нет тегов. Создайте их в разделе "Мои теги".</p>
                        {% else %}
                            {% for tag in userTags|default([]) %}
                                <div>
                                    <input type="checkbox" class="btn-check tag-checkbox" id="tag_{{ tag.id }}" value="{{ tag.id }}" data-name="{{ tag.name|e('html_attr') }}" autocomplete="off">
                                    <label class="btn btn-outline-primary rounded-pill px-3 py-1" for="tag_{{ tag.id }}">{{ tag.name }}</label>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                <div class="modal-footer justify-content-center gap-2">
                    <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal" id="save-tags-button">
                        Готово
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_scripts %}
    <script src="https://api-maps.yandex.ru/2.1/?lang=ru_RU" defer></script>
    <script src="{{ asset('assets/js/ymap-resize.js') }}" defer></script>
    <script src="{{ asset('assets/js/placemark-create.js') }}" defer></script>
{% endblock %}
