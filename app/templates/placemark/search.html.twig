{% extends 'layout.html.twig' %}

{% block title %}Поиск меток{% endblock %}

{% block content %}
    <h1 class="h3 mb-4">Поиск меток</h1>

    <section>
        <div
            id="search-map"
            class="search-map"
            data-center-lat="{{ mapCenterLat }}"
            data-center-lon="{{ mapCenterLon }}"
            data-default-radius="{{ defaultRadiusMeters }}"
            data-api-url="{{ path('api_placemarker_search') }}"
            data-get-url="{{ path('api_search_get_placemarker', {id: '__ID__'}) }}"
            data-save-url="{{ path('api_placemarker_collection_save') }}"
            data-collections-url="{{ path('api_placemarker_collection_list') }}"
        ></div>

        <div class="search-controls mt-3">
            <div class="search-hint mb-3">
                Кликните на карте дважды, чтобы задать центр и радиус области поиска. Окружность можно перетаскивать и изменять размер с помощью маркеров по краям.
            </div>

            <div class="d-flex flex-wrap align-items-center gap-3">
                <button type="button" id="search-button" class="btn btn-primary d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search me-2" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>
                    <span class="btn-label">Найти</span>
                </button>

                <p id="search-results-count" class="search-results-count mb-0" hidden>
                    Найдено <strong id="search-results-count-value">0</strong> <span id="search-results-count-label">меток</span>
                </p>

                <button type="button" id="save-search-button" class="btn btn-outline-success d-flex align-items-center" disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-bookmark me-2" viewBox="0 0 16 16"><path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.74.439L8 13.069l-5.26 2.87A.5.5 0 0 1 2 15.5zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.582a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1z"/></svg>
                    Сохранить поиск
                </button>

                <div class="ms-auto">
                    <button type="button" id="show-collections-button" class="btn btn-outline-secondary d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-collection me-2" viewBox="0 0 16 16"><path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zm1.5-.5A.5.5 0 0 1 1 12V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-.5.5z"/></svg>
                        Сохранённые поиски
                        <span id="collections-count-badge" class="badge bg-secondary ms-2 rounded-pill">0</span>
                    </button>
                </div>
            </div>
        </div>

        <div id="search-filter-toolbar" class="search-filter-toolbar mt-3"
             data-types="{{ placemarkerTypes|default([])|json_encode|e('html_attr') }}"
             data-tags="{{ userTags|default([])|json_encode|e('html_attr') }}">
            <div class="search-filter-toolbar__header">
                <div class="search-filter-toolbar__title">
                    <span class="search-filter-toolbar__icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2z"/></svg>
                    </span>
                    <div>
                        <span class="search-filter-toolbar__label">Фильтры поиска</span>
                        <span class="search-filter-toolbar__subtitle">Выберите тип метки, затем теги этого типа. Можно добавить несколько пар фильтров.</span>
                    </div>
                </div>
                <button type="button" id="search-filters-reset-button" class="btn btn-sm search-filter-toolbar__reset" disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/></svg>
                    Сбросить все
                </button>
            </div>

            <div class="search-filter-toolbar__body">
                <div id="search-filter-pairs" class="d-flex flex-column gap-3"></div>
            </div>
        </div>
    </section>

    <section class="placemark-section placemark-section--cards mt-4">
        <div class="placemark-section__header">
            <h2 class="placemark-section__title h5 mb-0">Результаты поиска</h2>
        </div>
        <div class="placemark-section__body">
            <div id="search-results-list" class="row g-2 placemark-saved-list"></div>
            <p class="search-results-empty mb-0">Здесь появятся найденные метки</p>
        </div>
    </section>

    <div class="modal fade placemark-info-modal" id="placemark-info-modal" tabindex="-1" aria-labelledby="placemark-info-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered placemark-info-modal-dialog">
            <div class="modal-content placemark-info-modal-content">
                <div class="modal-header placemark-info-modal-header">
                    <div class="placemark-info-modal-header__main">
                        <span class="placemark-info-modal-pin" aria-hidden="true">📍</span>
                        <div>
                            <h5 class="modal-title" id="placemark-info-modal-label">Информация о метке</h5>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body placemark-info-modal-body">
                    <div id="placemark-info-loading" class="placemark-info-loading" hidden>
                        <span class="spinner-border text-primary" role="status" aria-hidden="true"></span>
                        <span class="placemark-info-loading__text">Загрузка данных…</span>
                    </div>

                    <div id="placemark-info-error" class="alert alert-danger placemark-info-error mb-0" role="alert" hidden></div>

                    <div id="placemark-info-content" class="placemark-info-content">
                        <div class="placemark-info-hero">
                            <h3 id="placemark-info-name" class="placemark-info-hero__title"></h3>
                            <span id="placemark-info-type" class="placemark-info-type-badge"></span>
                        </div>

                        <div class="placemark-info-grid">
                            <section class="placemark-info-card placemark-info-card--coords">
                                <div class="placemark-info-card__header">
                                    <span class="placemark-info-card__icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                                    </span>
                                    <span class="placemark-info-card__label">Координаты</span>
                                </div>
                                <div class="placemark-info-coords">
                                    <div class="placemark-info-coord">
                                        <span class="placemark-info-coord__label">Широта</span>
                                        <span id="placemark-info-lat" class="placemark-info-coord__value"></span>
                                    </div>
                                    <div class="placemark-info-coord">
                                        <span class="placemark-info-coord__label">Долгота</span>
                                        <span id="placemark-info-lon" class="placemark-info-coord__value"></span>
                                    </div>
                                </div>
                            </section>

                            <section class="placemark-info-card placemark-info-card--tags">
                                <div class="placemark-info-card__header">
                                    <span class="placemark-info-card__icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                    </span>
                                    <span class="placemark-info-card__label">Теги</span>
                                </div>
                                <div id="placemark-info-tags" class="placemark-info-tags"></div>
                                <p id="placemark-info-tags-empty" class="placemark-info-empty-hint mb-0" hidden>Теги не указаны</p>
                            </section>

                            <section class="placemark-info-card placemark-info-card--description">
                                <div class="placemark-info-card__header">
                                    <span class="placemark-info-card__icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                                    </span>
                                    <span class="placemark-info-card__label">Описание</span>
                                </div>
                                <div id="placemark-info-description" class="placemark-info-description"></div>
                            </section>
                        </div>

                        <div class="placemark-info-meta">
                            <span class="placemark-info-meta__icon" aria-hidden="true">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </span>
                            <span class="placemark-info-meta__label">Добавлена:</span>
                            <span id="placemark-info-created-at" class="placemark-info-meta__value"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer placemark-info-modal-footer justify-content-center">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade placemark-edit-modal" id="save-search-modal" tabindex="-1" aria-labelledby="save-search-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered placemark-edit-modal-dialog">
            <div class="modal-content placemark-edit-modal-content">
                <div class="modal-header placemark-edit-modal-header">
                    <h5 class="modal-title" id="save-search-modal-label">Сохранить подборку</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <label for="collection-name-input" class="form-label">Название подборки</label>
                    <input
                        type="text"
                        class="form-control"
                        id="collection-name-input"
                        maxlength="255"
                        placeholder="Например: Кафе в центре"
                        autocomplete="off"
                    >
                    <div id="save-search-error" class="invalid-feedback d-block" hidden></div>
                </div>
                <div class="modal-footer placemark-edit-modal-footer justify-content-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" id="save-search-confirm-button" class="btn btn-success">
                        <span class="btn-label">Сохранить</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade placemark-edit-modal" id="collections-list-modal" tabindex="-1" aria-labelledby="collections-list-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered placemark-edit-modal-dialog">
            <div class="modal-content placemark-edit-modal-content">
                <div class="modal-header placemark-edit-modal-header">
                    <h5 class="modal-title" id="collections-list-modal-label">Сохранённые поиски</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle collections-list-table">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="ps-4">Название</th>
                                    <th scope="col" class="collections-list-col-count">Кол-во меток</th>
                                    <th scope="col" class="collections-list-col-date">Дата</th>
                                    <th scope="col" class="text-end pe-4 collections-list-col-actions">Действия</th>
                                </tr>
                            </thead>
                            <tbody id="collections-list-tbody">
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Загрузка...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade placemark-tags-modal" id="search-tags-modal" tabindex="-1" aria-labelledby="search-tags-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="search-tags-modal-label">Фильтр по тегам</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="placemark-tags-list d-flex flex-wrap gap-2" id="search-tags-list"></div>
                    <p id="search-tags-modal-empty" class="text-muted w-100 text-center mb-0" hidden>Для выбранного типа пока нет тегов.</p>
                </div>
                <div class="modal-footer justify-content-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="search-tags-clear-button">Сбросить</button>
                    <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal" id="search-tags-apply-button">Готово</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade placemark-tags-modal" id="search-types-modal" tabindex="-1" aria-labelledby="search-types-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="search-types-modal-label">Выберите тип метки</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="placemark-tags-list d-flex flex-wrap gap-2" id="search-types-list"></div>
                    <p id="search-types-modal-empty" class="text-muted w-100 text-center mb-0" hidden>Нет доступных типов.</p>
                </div>
                <div class="modal-footer justify-content-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal" id="search-types-apply-button">Выбрать</button>
                </div>
            </div>
        </div>
    </div>

    <template id="placemark-saved-card-template">
        <div class="col-6 col-sm-4 col-md-3 col-lg-2">
            <div class="card placemark-saved-card h-100" role="button" tabindex="0">
                <div class="card-body position-relative text-center p-3">
                    <div class="placemark-saved-pin" aria-hidden="true">📍</div>
                    <div class="placemark-saved-name fw-semibold text-truncate" title=""></div>
                    <div class="placemark-saved-coords mt-1">
                        <div class="placemark-saved-lat text-truncate" title=""></div>
                        <div class="placemark-saved-lon text-truncate" title=""></div>
                    </div>
                </div>
            </div>
        </div>
    </template>
{% endblock %}

{% block page_scripts %}
    <script src="https://api-maps.yandex.ru/2.1/?lang=ru_RU" defer></script>
    <script src="{{ asset('assets/js/ymap-resize.js') }}?v={{ asset_mtime('assets/js/ymap-resize.js') }}" defer></script>
    <script src="{{ asset('assets/js/circle-handler.js') }}?v={{ asset_mtime('assets/js/circle-handler.js') }}" defer></script>
    <script src="{{ asset('assets/js/placemark-search.js') }}?v={{ asset_mtime('assets/js/placemark-search.js') }}" defer></script>
{% endblock %}
