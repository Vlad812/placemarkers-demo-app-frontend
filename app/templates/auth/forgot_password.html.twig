{% extends 'base.html.twig' %}

{% block title %}Забыли пароль - Placemarkers{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light" style="background: radial-gradient(circle, rgba(238,242,251,1) 0%, rgba(219,228,247,1) 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="display-4 text-warning mb-2">🔑</div>
                            <h1 class="h3 fw-bold text-dark mb-1">Забыли пароль?</h1>
                            <p class="text-muted small">Введите email — мы отправим ссылку для сброса пароля</p>
                        </div>

                        {% if success %}
                            <div class="alert alert-success mb-4" role="alert">
                                <div class="small">{{ success }}</div>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="alert alert-danger mb-4" role="alert">
                                <div class="small">{{ error }}</div>
                            </div>
                        {% endif %}

                        {% if not success %}
                            <form action="{{ path('auth_forgot_password') }}" method="POST" class="needs-validation" novalidate>
                                <div class="mb-4">
                                    <label for="email" class="form-label text-secondary small fw-semibold">Email адрес</label>
                                    <input type="email" class="form-control form-control-lg" id="email" name="email" value="{{ email }}" placeholder="name@example.com" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пожалуйста, введите корректный email.</div>
                                </div>

                                <button type="submit" class="btn btn-warning btn-lg w-100 mb-3 text-dark fw-semibold" style="border-radius: 0.5rem;">Отправить ссылку</button>
                            </form>
                        {% endif %}

                        <div class="text-center mt-3">
                            <a href="{{ loginUrl }}" class="text-primary fw-semibold text-decoration-none small">← Вернуться ко входу</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if not success %}
<script>
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms)
            .forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
    })()
</script>
{% endif %}
{% endblock %}
