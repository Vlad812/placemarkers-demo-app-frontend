{% extends 'base.html.twig' %}

{% block title %}Вход - Placemarkers{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light" style="background: radial-gradient(circle, rgba(238,242,251,1) 0%, rgba(219,228,247,1) 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="display-4 text-primary mb-2">📍</div>
                            <h1 class="h3 font-weight-bold text-dark mb-1">Placemarkers</h1>
                            <p class="text-muted small">Войдите в свой аккаунт</p>
                        </div>

                        {% if error %}
                            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                                <div class="small">{{ error }}</div>
                            </div>
                        {% endif %}

                        <form action="{{ path('auth_login') }}" method="POST" class="needs-validation" novalidate>
                            <div class="mb-3">
                                <label for="email" class="form-label text-secondary small fw-semibold">Email адрес</label>
                                <div class="input-group">
                                    <input type="email" class="form-control form-control-lg" id="email" name="email" value="{{ email }}" placeholder="name@example.com" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пожалуйста, введите корректный email.</div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label for="password" class="form-label text-secondary small fw-semibold mb-0">Пароль</label>
                                    <a href="{{ path('auth_forgot_password_page') }}" class="text-primary small text-decoration-none">Забыли пароль?</a>
                                </div>
                                <div class="input-group">
                                    <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="••••••••" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пожалуйста, введите пароль.</div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" style="border-radius: 0.5rem; background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); border: none;">Войти</button>
                        </form>

                        <div class="text-center mt-3">
                            <p class="text-muted small mb-0">Нет аккаунта? <a href="{{ path('auth_signup_page') }}" class="text-primary fw-semibold text-decoration-none">Зарегистрироваться</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms)
            .forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
    })()
</script>
{% endblock %}
