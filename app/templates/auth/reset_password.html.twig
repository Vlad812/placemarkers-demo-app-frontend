{% extends 'base.html.twig' %}

{% block title %}Сброс пароля - Placemarkers{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light" style="background: radial-gradient(circle, rgba(238,242,251,1) 0%, rgba(219,228,247,1) 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
                    <div class="card-body p-5">
                        {% if success %}
                            <div class="text-center">
                                <div class="display-4 text-success mb-3">✓</div>
                                <h1 class="h3 fw-bold text-dark mb-3">Пароль изменён</h1>
                                <p class="text-muted mb-4">{{ success }}</p>
                                <a href="{{ loginUrl }}" class="btn btn-primary btn-lg w-100" style="border-radius: 0.5rem;">Войти</a>
                            </div>
                        {% else %}
                            <div class="text-center mb-4">
                                <div class="display-4 text-primary mb-2">🔒</div>
                                <h1 class="h3 fw-bold text-dark mb-1">Новый пароль</h1>
                                <p class="text-muted small">Придумайте новый пароль для вашего аккаунта</p>
                            </div>

                            {% if error %}
                                <div class="alert alert-danger mb-4" role="alert">
                                    <div class="small">{{ error }}</div>
                                </div>
                            {% endif %}

                            <form action="{{ path('auth_reset_password', { token: token }) }}" method="POST" class="needs-validation" id="reset-form" novalidate>
                                <div class="mb-3">
                                    <label for="password" class="form-label text-secondary small fw-semibold">Новый пароль</label>
                                    <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="Минимум 8 символов" required minlength="8" style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пароль должен быть не менее 8 символов.</div>
                                </div>

                                <div class="mb-4">
                                    <label for="confirm_password" class="form-label text-secondary small fw-semibold">Подтвердите пароль</label>
                                    <input type="password" class="form-control form-control-lg" id="confirm_password" name="confirm_password" placeholder="••••••••" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback" id="confirm-feedback">Пожалуйста, подтвердите пароль.</div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" style="border-radius: 0.5rem;">Сохранить пароль</button>
                            </form>

                            <div class="text-center mt-3">
                                <a href="{{ loginUrl }}" class="text-primary fw-semibold text-decoration-none small">← Вернуться ко входу</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if not success %}
<script>
    (function () {
        'use strict'
        var form = document.getElementById('reset-form')
        var password = document.getElementById('password')
        var confirmPassword = document.getElementById('confirm_password')
        var confirmFeedback = document.getElementById('confirm-feedback')

        form.addEventListener('submit', function (event) {
            var valid = true

            if (password.value !== confirmPassword.value) {
                confirmPassword.setCustomValidity('Пароли не совпадают')
                confirmFeedback.textContent = 'Пароли не совпадают.'
                valid = false
            } else {
                confirmPassword.setCustomValidity('')
            }

            if (!form.checkValidity() || !valid) {
                event.preventDefault()
                event.stopPropagation()
            }
            form.classList.add('was-validated')
        }, false)

        confirmPassword.addEventListener('input', function () {
            if (password.value === confirmPassword.value) {
                confirmPassword.setCustomValidity('')
            } else {
                confirmPassword.setCustomValidity('Пароли не совпадают')
            }
        })
    })()
</script>
{% endif %}
{% endblock %}
