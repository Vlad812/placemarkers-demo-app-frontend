{% extends 'base.html.twig' %}

{% block title %}Регистрация - Placemarkers{% endblock %}

{% block body %}
    <div class="min-vh-100 d-flex align-items-center justify-content-center bg-light" style="background: radial-gradient(circle, rgba(238,242,251,1) 0%, rgba(219,228,247,1) 100%);">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
                        <div class="card-body p-5">
                            <div class="text-center mb-4">
                                <div class="display-4 text-success mb-2">📍</div>
                                <h1 class="h3 font-weight-bold text-dark mb-1">Регистрация</h1>
                                <p class="text-muted small">Создайте новый аккаунт</p>
                            </div>

                            <div id="signup-alert"></div>

                            <form action="{{ path('auth_signup') }}" method="POST" class="needs-validation" id="signup-form" novalidate>
                                <div class="mb-3">
                                    <label for="email" class="form-label text-secondary small fw-semibold">Email адрес</label>
                                    <input type="email" class="form-control form-control-lg" id="email" name="email" value="{{ email }}" placeholder="name@example.com" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пожалуйста, введите корректный email.</div>
                                </div>

                                <div class="mb-3">
                                    <label for="password" class="form-label text-secondary small fw-semibold">Пароль</label>
                                    <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="Минимум 8 символов" required minlength="8" style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback">Пароль должен быть не менее 8 символов.</div>
                                </div>

                                <div class="mb-4">
                                    <label for="confirm_password" class="form-label text-secondary small fw-semibold">Подтвердите пароль</label>
                                    <input type="password" class="form-control form-control-lg" id="confirm_password" name="confirm_password" placeholder="••••••••" required style="border-radius: 0.5rem;">
                                    <div class="invalid-feedback" id="confirm-feedback">Пожалуйста, подтвердите пароль.</div>
                                </div>

                                <button type="submit" class="btn btn-success btn-lg w-100 mb-3" id="signup-submit" style="border-radius: 0.5rem; background: linear-gradient(135deg, #198754 0%, #157347 100%); border: none;">Зарегистрироваться</button>
                            </form>

                            <div class="text-center mt-3">
                                <p class="text-muted small mb-0">Уже есть аккаунт? <a href="{{ path('auth_login_page') }}" class="text-success fw-semibold text-decoration-none">Войти</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            'use strict'
            var form = document.getElementById('signup-form')
            var password = document.getElementById('password')
            var confirmPassword = document.getElementById('confirm_password')
            var confirmFeedback = document.getElementById('confirm-feedback')
            var alertContainer = document.getElementById('signup-alert')
            var submitButton = document.getElementById('signup-submit')

            function showAlert(type, message) {
                alertContainer.innerHTML =
                    '<div class="alert alert-' + type + ' mb-4" role="alert">' +
                    '<div class="small">' + message + '</div>' +
                    '</div>'
            }

            function clearAlert() {
                alertContainer.innerHTML = ''
            }

            function setSubmitting(isSubmitting) {
                submitButton.disabled = isSubmitting
                submitButton.textContent = isSubmitting ? 'Регистрация...' : 'Зарегистрироваться'
            }

            form.addEventListener('submit', function (event) {
                event.preventDefault()
                var valid = true

                if (password.value !== confirmPassword.value) {
                    confirmPassword.setCustomValidity('Пароли не совпадают')
                    confirmFeedback.textContent = 'Пароли не совпадают.'
                    valid = false
                } else {
                    confirmPassword.setCustomValidity('')
                }

                form.classList.add('was-validated')

                if (!form.checkValidity() || !valid) {
                    return
                }

                clearAlert()
                setSubmitting(true)

                fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'Accept': 'application/json',
                    },
                })
                    .then(function (response) {
                        return response.json().then(function (data) {
                            return { ok: response.ok, status: response.status, data: data }
                        })
                    })
                    .then(function (result) {
                        var data = result.data || {}
                        var message = data.success || data.error || data.message || 'Неизвестная ошибка.'

                        if (result.ok && data.success) {
                            showAlert('success', message)
                            form.reset()
                            form.classList.remove('was-validated')
                            return
                        }

                        showAlert('danger', message)
                    })
                    .catch(function () {
                        showAlert('danger', 'Не удалось выполнить запрос. Попробуйте позже.')
                    })
                    .finally(function () {
                        setSubmitting(false)
                    })
            }, false)

            confirmPassword.addEventListener('input', function () {
                if (password.value === confirmPassword.value) {
                    confirmPassword.setCustomValidity('')
                } else {
                    confirmPassword.setCustomValidity('Пароли не совпадают')
                }
            })
        })()
    </script>
{% endblock %}
