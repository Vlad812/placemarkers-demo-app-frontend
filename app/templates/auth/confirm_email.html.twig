{% extends 'base.html.twig' %}

{% block title %}Подтверждение email - Placemarkers{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light" style="background: radial-gradient(circle, rgba(238,242,251,1) 0%, rgba(219,228,247,1) 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-5">
                <div class="card border-0 shadow-lg" style="border-radius: 1rem; overflow: hidden;">
                    <div class="card-body p-5 text-center">
                        {% if success %}
                            <div class="display-4 text-success mb-3">✓</div>
                            <h1 class="h3 fw-bold text-dark mb-3">Email подтверждён</h1>
                            <p class="text-muted mb-4">
                                Аккаунт активирован. На вашу почту также отправлено приветственное письмо.
                            </p>
                            <a href="{{ loginUrl }}" class="btn btn-primary btn-lg w-100" style="border-radius: 0.5rem;">Войти</a>
                        {% else %}
                            <div class="display-4 text-danger mb-3">!</div>
                            <h1 class="h3 fw-bold text-dark mb-3">Не удалось подтвердить email</h1>
                            <p class="text-muted mb-4">{{ error }}</p>
                            <a href="{{ loginUrl }}" class="btn btn-outline-primary btn-lg w-100" style="border-radius: 0.5rem;">На страницу входа</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
